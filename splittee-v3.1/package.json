{
  "name": "splittee-v2.1",
  "version": "2.1.0",
  "description": "Embeddable golf payment splitting platform with Stripe Connect",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:setup": "psql $DATABASE_URL -f schema.sql",
    "db:reset": "psql $DATABASE_URL -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;' && npm run db:setup",
    "test": "jest",
    "lint": "eslint ."
  },
  "keywords": [
    "golf",
    "payments",
    "stripe",
    "split-payments",
    "tee-time",
    "booking"
  ],
  "author": "Dorn Ventures LLC",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.13",
    "pg": "^8.11.5",
    "stripe": "^15.5.0",
    "twilio": "^5.0.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0"
  }
}
